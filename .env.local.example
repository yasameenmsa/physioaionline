# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/physioaionline
# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/physioaionline

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-change-this-in-production

# JWT Secret
JWT_SECRET=your-jwt-secret-change-this-in-production

# Admin Email (for admin dashboard access)
ADMIN_EMAIL=admin@physioai.online

# Email Service (Resend - optional for MVP)
RESEND_API_KEY=your-resend-api-key

# Email Configuration
EMAIL_FROM=noreply@physioai.online
EMAIL_SERVICE=resend

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
